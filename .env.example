# Example environment configuration (DO NOT put real secrets here)
# Copy to .env and fill with your own values.

APP_ENV=local
APP_DEBUG=true

DB_HOST=127.0.0.1
DB_NAME=pcu_rfid
DB_USER=root
DB_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# SMTP (Gmail or other provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=

# Security / crypto
JWT_SECRET=
FACE_ENCRYPTION_KEY=
